DIFY_ORIGIN=http://localhost
EMAIL=your-email@example.com
PASSWORD=your-password

# Folder used by both export.py and import.py.
DSL_FOLDER_PATH=./dsl

# Where prune_deleted.py moves the exported YAML of deleted workflows.
# Optional: defaults to a sibling "...-trashcan" folder next to DSL_FOLDER_PATH.
# DSL_TRASHCAN_PATH=./dsl-trashcan

# Where `./run.sh readable` writes the generated Markdown reports.
# Optional: defaults to ./readable (or override per-run with --out).
# READABLE_FOLDER_PATH=./readable

# Target for `./run.sh readable --output confluence` and the web app's
# "Generate & publish" action (one page per workflow). Required for doc
# publishing; leave unset to disable it.
# CONFLUENCE_DOCS_SPACE=YOURSPACE
# CONFLUENCE_DOCS_PARENT_ID=123456789

# Mermaid -> image rendering for Confluence pages (Kroki). Defaults to public kroki.io.
# Point at a local instance for privacy/speed (see README). Format: svg (default) or png.
# KROKI_URL=https://kroki.io
# KROKI_FORMAT=svg
# KROKI_TIMEOUT=45

# Keep this false for team sharing. Set to true only when you intentionally
# need exported workflow environment variable values/secrets in the YAML.
DIFY_INCLUDE_SECRET=false

# Accounts to ignore when the dashboard guesses a workflow's author from Dify
# version/draft history. The bulk-import/service account shows up as
# creator/editor on every app, so it's noise. Comma-separated emails.
# AUTHOR_SUGGESTION_IGNORE_EMAILS=importer@example.com

# --- Confluence tracker sync (src/sync_tracker.py) ---
# Confluence Cloud base URL, including the /wiki suffix.
CONFLUENCE_BASE_URL=https://your-site.atlassian.net/wiki
# Atlassian account email that owns the API token below.
CONFLUENCE_EMAIL=your-email@example.com
# API token: https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_API_TOKEN=your-confluence-api-token
# Numeric id of the tracker page to keep in sync.
CONFLUENCE_PAGE_ID=123456789

# --- Slack notification (src/slack_notify.py) ---
# Incoming webhook URL for the channel that should receive the status message.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
# Optional: map author names (as they appear in the tracker) to Slack user IDs
# so notifications @-mention them. JSON object, lowercase names.
# SLACK_USER_MAP={"jane doe":"U012ABCDEF","john":"U034GHIJKL"}

# --- Web app backend (src/api) ---
# REQUIRED: secret used to sign the login session cookie. Generate one with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# If unset, the app generates a random per-process secret (logins won't persist
# across restarts).
SESSION_SECRET=change-me-to-a-long-random-string
# Dify workspace roles allowed to run destructive actions (prune). Comma-separated.
# Optional: defaults to "owner,admin".
# ADMIN_ROLES=owner,admin
# Emails always treated as admin (prune/delete/settings/YAML export), regardless
# of Dify role. Comma-separated. This is how you grant admin in a self-hosted
# deployment.
# ADMIN_EMAILS=you@example.com
# Browser origin(s) of the frontend, for CORS. Optional: defaults to http://localhost:3000.
# FRONTEND_ORIGINS=http://localhost:3000
