DIFY_ORIGIN=http://localhost
EMAIL=your-email@example.com
PASSWORD=your-password

# Folder used by both export.py and import.py.
DSL_FOLDER_PATH=./dsl

# Where prune_deleted.py moves the exported YAML of deleted workflows.
# Optional: defaults to a sibling "...-trashcan" folder next to DSL_FOLDER_PATH.
# DSL_TRASHCAN_PATH=./dsl-trashcan

# Where `./run.sh readable` writes the generated Markdown reports.
# Optional: defaults to ./dify-pelonis-readable (or override per-run with --out).
# READABLE_FOLDER_PATH=./dify-pelonis-readable

# Keep this false for team sharing. Set to true only when you intentionally
# need exported workflow environment variable values/secrets in the YAML.
DIFY_INCLUDE_SECRET=false

# --- Confluence tracker sync (src/sync_tracker.py) ---
# Confluence Cloud base URL, including the /wiki suffix.
CONFLUENCE_BASE_URL=https://your-site.atlassian.net/wiki
# Atlassian account email that owns the API token below.
CONFLUENCE_EMAIL=your-email@example.com
# API token: https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_API_TOKEN=your-confluence-api-token
# Numeric id of the tracker page to keep in sync.
CONFLUENCE_PAGE_ID=407797761

# --- Slack notification (src/slack_notify.py) ---
# Incoming webhook URL for the channel that should receive the status message.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# --- Web app backend (src/api) ---
# Secret used to sign the login session cookie. Set a long random value.
SESSION_SECRET=change-me-to-a-long-random-string
# Dify workspace roles allowed to run destructive actions (prune). Comma-separated.
# Optional: defaults to "owner,admin".
# ADMIN_ROLES=owner,admin
# Extra emails always treated as admin, regardless of Dify role. Comma-separated.
# Optional: useful if role lookup is unavailable.
# ADMIN_EMAILS=
# Browser origin(s) of the frontend, for CORS. Optional: defaults to http://localhost:3000.
# FRONTEND_ORIGINS=http://localhost:3000
